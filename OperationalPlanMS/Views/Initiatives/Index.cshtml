@model OperationalPlanMS.Models.ViewModels.InitiativeListViewModel
@{
    ViewData["Title"] = "المبادرات";
    var canEdit = (bool)(ViewBag.CanEdit ?? false);
}

<style>
    .welcome-banner {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        padding: 2rem;
        color: white;
    }
</style>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4 welcome-banner">
    <div>
        <h4 class="mb-1">إدارة المبادرات</h4>
        <p class="text-white mb-0">عرض وإدارة جميع المبادرات</p>
    </div>
    @if (canEdit)
    {
        <a href="/Initiatives/Create" class="btn btn-light">
            <i class="bi bi-plus-circle me-2"></i>إضافة مبادرة
        </a>
    }
</div>

<!-- Filters Card -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="row g-3">
                <!-- البحث -->
                <div class="col-md-3">
                    <label class="form-label">البحث</label>
                    <input type="text" class="form-control" asp-for="SearchTerm" placeholder="البحث بالاسم أو الكود..." />
                </div>

                <!-- السنة المالية -->
                <div class="col-md-2">
                    <label class="form-label">السنة المالية</label>
                    <select class="form-select" asp-for="FiscalYearId" asp-items="Model.FiscalYears">
                        <option value="">-- الكل --</option>
                    </select>
                </div>

                <!-- المستوى الأول -->
                <div class="col-md-2">
                    <label class="form-label">المستوى الأول</label>
                    <select class="form-select" id="filterLevel1" name="Level1Id">
                        <option value="">-- جاري التحميل --</option>
                    </select>
                </div>

                <!-- المستوى الثاني -->
                <div class="col-md-2">
                    <label class="form-label">المستوى الثاني</label>
                    <select class="form-select" id="filterLevel2" name="Level2Id" disabled>
                        <option value="">-- اختر المستوى الأول --</option>
                    </select>
                </div>

                <!-- المستوى الثالث -->
                <div class="col-md-2">
                    <label class="form-label">المستوى الثالث</label>
                    <select class="form-select" id="filterLevel3" name="Level3Id" disabled>
                        <option value="">-- اختر المستوى الثاني --</option>
                    </select>
                </div>

                <!-- Hidden field for selected unit -->
                <input type="hidden" id="ExternalUnitId" name="ExternalUnitId" value="@ViewBag.ExternalUnitId" />

                <!-- أزرار البحث -->
                <div class="col-md-1 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-search"></i>
                    </button>
                    <a href="/Initiatives" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results Info -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted">عرض @Model.Initiatives.Count من @Model.TotalCount نتيجة</span>
</div>

<!-- Initiatives Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width: 100px;">الكود</th>
                        <th>المبادرة</th>
                        <th>الوحدة التنظيمية</th>
                        <th>المشرف</th>
                        <th style="width: 100px;">المشاريع</th>
                        <th style="width: 140px;">التواريخ</th>
                        <th style="width: 100px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Initiatives.Any())
                    {
                        @foreach (var item in Model.Initiatives)
                        {
                            var projectsCount = item.Projects?.Count(p => !p.IsDeleted) ?? 0;

                            var unitName = !string.IsNullOrEmpty(item.ExternalUnitName)
                            ? item.ExternalUnitName
                            : item.OrganizationalUnit?.NameAr ?? "-";

                            var orgName = !string.IsNullOrEmpty(item.ExternalUnitName)
                            ? ""
                            : item.OrganizationalUnit?.Organization?.NameAr ?? "";

                            var supervisorName = !string.IsNullOrEmpty(item.SupervisorName)
                            ? item.SupervisorName
                            : item.Supervisor?.FullNameAr ?? "-";

                            var supervisorRank = !string.IsNullOrEmpty(item.SupervisorRank)
                            ? item.SupervisorRank
                            : "";

                            var supervisorEmpNumber = !string.IsNullOrEmpty(item.SupervisorEmpNumber)
                            ? item.SupervisorEmpNumber
                            : "";

                            <tr>
                                <td><code>@item.Code</code></td>
                                <td>
                                    <a href="/Initiatives/Details/@item.Id" class="fw-bold text-decoration-none">
                                        @item.NameAr
                                    </a>
                                    @if (!string.IsNullOrEmpty(item.NameEn))
                                    {
                                        <br>
                                        <small class="text-muted">@item.NameEn</small>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(orgName))
                                    {
                                        <small class="text-muted">@orgName</small>
                                        <br>
                                    }
                                    <span>@unitName</span>
                                </td>
                                <td>
                                    <span>@supervisorName</span>
                                    @if (!string.IsNullOrEmpty(supervisorRank))
                                    {
                                        <br>
                                        <small class="text-muted">@supervisorRank</small>
                                    }
                                    @if (!string.IsNullOrEmpty(supervisorEmpNumber))
                                    {
                                        <br>
                                        <small class="text-secondary"><i class="bi bi-person-badge me-1"></i>@supervisorEmpNumber</small>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary rounded-pill">@projectsCount</span>
                                </td>
                                <td>
                                    @if (item.ActualStartDate.HasValue)
                                    {
                                        <small class="text-muted d-block">
                                            <i class="bi bi-calendar-event me-1"></i>@item.ActualStartDate.Value.ToString("yyyy-MM-dd")
                                        </small>
                                    }
                                    @if (item.ActualEndDate.HasValue)
                                    {
                                        <small class="text-muted d-block">
                                            <i class="bi bi-calendar-check me-1"></i>@item.ActualEndDate.Value.ToString("yyyy-MM-dd")
                                        </small>
                                    }
                                    @if (!item.ActualStartDate.HasValue && !item.ActualEndDate.HasValue)
                                    {
                                        <small class="text-muted">-</small>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Initiatives/Details/@item.Id" class="btn btn-outline-primary" title="عرض">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (canEdit)
                                        {
                                            <a href="/Initiatives/Edit/@item.Id" class="btn btn-outline-warning" title="تعديل">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/Initiatives/Delete/@item.Id" class="btn btn-outline-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                                <p class="text-muted mt-2 mb-0">لا توجد مبادرات</p>
                                @if (canEdit)
                                {
                                    <a href="/Initiatives/Create" class="btn btn-primary mt-3">
                                        <i class="bi bi-plus-circle me-2"></i>إضافة مبادرة جديدة
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?CurrentPage=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm&FiscalYearId=@Model.FiscalYearId&ExternalUnitId=@ViewBag.ExternalUnitId">
                    السابق
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?CurrentPage=@i&SearchTerm=@Model.SearchTerm&FiscalYearId=@Model.FiscalYearId&ExternalUnitId=@ViewBag.ExternalUnitId">
                        @i
                    </a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?CurrentPage=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm&FiscalYearId=@Model.FiscalYearId&ExternalUnitId=@ViewBag.ExternalUnitId">
                    التالي
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        // متغيرات عامة
        var allUnits = [];
        var selectedExternalUnitId = '@(ViewBag.ExternalUnitId ?? "")';

        // انتظار تحميل الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            loadOrganizationalUnits();

            // Event listeners للقوائم
            document.getElementById('filterLevel1').addEventListener('change', onLevel1Change);
            document.getElementById('filterLevel2').addEventListener('change', onLevel2Change);
            document.getElementById('filterLevel3').addEventListener('change', onLevel3Change);
        });

        // تحميل الوحدات التنظيمية من API
        function loadOrganizationalUnits() {
            fetch('/api/OrganizationApi/units/all')
                .then(function(response) {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.json();
                })
                .then(function(data) {
                    console.log('Units loaded:', data.length);
                    allUnits = data;
                    populateFilterLevel1();

                    // استعادة الفلتر المحدد
                    if (selectedExternalUnitId) {
                        restoreFilterSelection(parseInt(selectedExternalUnitId));
                    }
                })
                .catch(function(error) {
                    console.error('Error loading units:', error);
                    document.getElementById('filterLevel1').innerHTML = '<option value="">-- فشل التحميل --</option>';
                });
        }

        // ملء المستوى الأول
        function populateFilterLevel1() {
            var level1Units = allUnits.filter(function(u) {
                return u.parentId === null || u.parentId === 0;
            });
            var select = document.getElementById('filterLevel1');
            select.innerHTML = '<option value="">-- الكل --</option>';

            level1Units.forEach(function(unit) {
                var option = document.createElement('option');
                option.value = unit.id;
                option.textContent = unit.name;
                select.appendChild(option);
            });

            console.log('Level 1 units:', level1Units.length);
        }

        // عند تغيير المستوى الأول
        function onLevel1Change() {
            var selectedId = parseInt(this.value);
            var level2Select = document.getElementById('filterLevel2');
            var level3Select = document.getElementById('filterLevel3');

            level2Select.innerHTML = '';
            level2Select.disabled = true;
            level3Select.innerHTML = '<option value="">-- اختر المستوى الثاني --</option>';
            level3Select.disabled = true;

            if (selectedId) {
                var children = allUnits.filter(function(u) {
                    return u.parentId === selectedId;
                });

                if (children.length > 0) {
                    level2Select.innerHTML = '<option value="">-- اختر --</option>';
                    children.forEach(function(unit) {
                        var option = document.createElement('option');
                        option.value = unit.id;
                        option.textContent = unit.name;
                        level2Select.appendChild(option);
                    });
                    level2Select.disabled = false;
                } else {
                    level2Select.innerHTML = '<option value="">-- لا توجد وحدات فرعية --</option>';
                }

                updateSelectedUnit(selectedId);
            } else {
                level2Select.innerHTML = '<option value="">-- اختر المستوى الأول --</option>';
                document.getElementById('ExternalUnitId').value = '';
            }
        }

        // عند تغيير المستوى الثاني
        function onLevel2Change() {
            var selectedId = parseInt(this.value);
            var level3Select = document.getElementById('filterLevel3');

            level3Select.innerHTML = '';
            level3Select.disabled = true;

            if (selectedId) {
                var children = allUnits.filter(function(u) {
                    return u.parentId === selectedId;
                });

                if (children.length > 0) {
                    level3Select.innerHTML = '<option value="">-- اختر --</option>';
                    children.forEach(function(unit) {
                        var option = document.createElement('option');
                        option.value = unit.id;
                        option.textContent = unit.name;
                        level3Select.appendChild(option);
                    });
                    level3Select.disabled = false;
                } else {
                    level3Select.innerHTML = '<option value="">-- لا توجد وحدات فرعية --</option>';
                }

                updateSelectedUnit(selectedId);
            } else {
                level3Select.innerHTML = '<option value="">-- اختر المستوى الثاني --</option>';
                var level1Val = parseInt(document.getElementById('filterLevel1').value);
                if (level1Val) {
                    updateSelectedUnit(level1Val);
                } else {
                    document.getElementById('ExternalUnitId').value = '';
                }
            }
        }

        // عند تغيير المستوى الثالث
        function onLevel3Change() {
            var selectedId = parseInt(this.value);

            if (selectedId) {
                updateSelectedUnit(selectedId);
            } else {
                var level2Val = parseInt(document.getElementById('filterLevel2').value);
                if (level2Val) {
                    updateSelectedUnit(level2Val);
                }
            }
        }

        // تحديث الوحدة المختارة
        function updateSelectedUnit(unitId) {
            document.getElementById('ExternalUnitId').value = unitId;
            console.log('Selected unit:', unitId);
        }

        // استعادة الفلتر المحدد
        function restoreFilterSelection(unitId) {
            var unit = allUnits.find(function(u) { return u.id === unitId; });
            if (!unit) return;

            // بناء سلسلة الآباء
            var hierarchy = [];
            var current = unit;

            while (current) {
                hierarchy.unshift(current);
                var parentId = current.parentId;
                current = allUnits.find(function(u) { return u.id === parentId; });
            }

            // تطبيق التحديد
            if (hierarchy.length >= 1) {
                document.getElementById('filterLevel1').value = hierarchy[0].id;
                onLevel1Change.call(document.getElementById('filterLevel1'));

                setTimeout(function() {
                    if (hierarchy.length >= 2) {
                        document.getElementById('filterLevel2').value = hierarchy[1].id;
                        onLevel2Change.call(document.getElementById('filterLevel2'));

                        setTimeout(function() {
                            if (hierarchy.length >= 3) {
                                document.getElementById('filterLevel3').value = hierarchy[2].id;
                                updateSelectedUnit(hierarchy[2].id);
                            }
                        }, 100);
                    }
                }, 100);
            }
        }
    </script>
}
