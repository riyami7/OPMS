@model OperationalPlanMS.Models.ViewModels.ReportsDashboardViewModel
@{
    ViewData["Title"] = "لوحة المتابعة التنفيذية";

    var totalItems = Model.TotalProjects + Model.TotalSteps;
    var delayedItems = Model.DelayedProjects + Model.OverdueSteps.Count;
    var healthScore = totalItems > 0 ? (int)Math.Round((1 - ((decimal)delayedItems / totalItems)) * 100) : 100;
    healthScore = Math.Max(0, Math.Min(100, healthScore));
    var healthColor = healthScore >= 80 ? "#0e7d5a" : healthScore >= 60 ? "#b45309" : "#b91c1c";
    var healthStatus = healthScore >= 80 ? "ممتاز" : healthScore >= 60 ? "يحتاج متابعة" : "يحتاج تدخل";
    double gaugeCircumference = Math.PI * 70;
    double gaugeDashOffset = gaugeCircumference * (1 - healthScore / 100.0);
}

<!-- HEADER -->
<div class="rpt-header mb-4">
    <div class="row align-items-center g-3">
        <div class="col-lg-5">
            <h4 class="mb-1 text-white fw-bold">
                <i class="bi bi-speedometer2 me-2"></i>لوحة المتابعة التنفيذية
            </h4>
            <p class="mb-0 text-white-50 small">
                @if (Model.CurrentFiscalYear != null)
                {
                    <span>@Model.CurrentFiscalYear.NameAr</span>

                    <span class="mx-2 opacity-50">|</span>
                }
                <span>@DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ar-OM"))</span>
                @if (!string.IsNullOrEmpty(Model.SelectedUnitName))
                {
                    <span class="mx-2 opacity-50">|</span>
                    <span class="badge bg-white bg-opacity-20 text-white">
                        <i class="bi bi-building me-1"></i>@Model.SelectedUnitName
                    </span>
                }
            </p>
        </div>
        <div class="col-lg-5">
            <div class="row g-2 text-white text-center">
                <div class="col-3">
                    <div class="rpt-qk">
                        <div class="rpt-qk-v">@Model.TotalInitiatives</div>
                        <div class="rpt-qk-l">مبادرة</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="rpt-qk">
                        <div class="rpt-qk-v">@Model.TotalProjects</div>
                        <div class="rpt-qk-l">مشروع</div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="rpt-qk">
                        <div class="rpt-qk-v">@Model.TotalSteps</div>
                        <div class="rpt-qk-l">خطوة</div>
                    </div>
                </div>
                <div class="col-3">
                    @if (delayedItems > 0)
                    {
                        <div class="rpt-qk rpt-qk-danger">
                            <div class="rpt-qk-v">@delayedItems</div>
                            <div class="rpt-qk-l">متأخر</div>
                        </div>
                    }
                    else
                    {
                        <div class="rpt-qk">
                            <div class="rpt-qk-v">@delayedItems</div>
                            <div class="rpt-qk-l">متأخر</div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-2 text-center">
            <div class="d-flex align-items-center justify-content-center gap-3">
                <div>
                    <svg viewBox="0 0 180 110" width="100" height="62">
                        <path d="M 20 90 A 70 70 0 0 1 160 90"
                              fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="13" stroke-linecap="round" />
                        <path d="M 20 90 A 70 70 0 0 1 160 90"
                              fill="none" stroke="@healthColor" stroke-width="13" stroke-linecap="round"
                              stroke-dasharray="@gaugeCircumference.ToString("F1")"
                              stroke-dashoffset="@gaugeDashOffset.ToString("F1")" />
                        <text x="90" y="84" text-anchor="middle" font-size="22" font-weight="800"
                              fill="white" font-family="AlQabas">@healthScore%</text>
                        <text x="90" y="99" text-anchor="middle" font-size="9"
                              fill="rgba(255,255,255,0.65)" font-family="AlQabas">@healthStatus</text>
                    </svg>
                    <div style="font-size:.68rem;color:rgba(255,255,255,.5);margin-top:-4px;">صحة الخطة</div>
                </div>
                <div class="dropdown">
                    <button class="btn btn-sm" style="background:rgba(255,255,255,.15);color:white;border:1px solid rgba(255,255,255,.2);"
                            data-bs-toggle="dropdown">
                        <i class="bi bi-download"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Reports/Export?type=initiatives&fiscalYearId=@Model.FiscalYearId&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-lightning-charge me-2 text-warning"></i>المبادرات</a></li>
                        <li><a class="dropdown-item" href="/Reports/Export?type=projects&fiscalYearId=@Model.FiscalYearId&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-folder me-2 text-success"></i>المشاريع</a></li>
                        <li><a class="dropdown-item" href="/Reports/Export?type=steps&fiscalYearId=@Model.FiscalYearId&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-list-check me-2 text-info"></i>الخطوات</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Reports/Export?type=overdue&externalUnitId=@Model.ExternalUnitId"><i class="bi bi-exclamation-triangle me-2"></i>المتأخرات</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FILTER -->
<div class="card mb-4">
    <div class="card-header" data-bs-toggle="collapse" data-bs-target="#filterSection" style="cursor:pointer;">
        <div class="d-flex justify-content-between align-items-center">
            <span><i class="bi bi-funnel me-2"></i><strong>فلاتر البحث</strong></span>
            <i class="bi bi-chevron-down"></i>
        </div>
    </div>
    <div class="collapse show" id="filterSection">
        <div class="card-body">
            <form method="get" asp-action="Index" id="filterForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label"><i class="bi bi-calendar3 me-1 text-primary"></i>السنة المالية</label>
                        <select class="form-select" asp-for="FiscalYearId" asp-items="Model.FiscalYears">
                            <option value="">-- جميع السنوات --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><i class="bi bi-building me-1 text-primary"></i>المستوى الأول</label>
                        <select class="form-select" id="filterLevel1"><option value="">-- جاري التحميل --</option></select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><i class="bi bi-diagram-2 me-1 text-info"></i>المستوى الثاني</label>
                        <select class="form-select" id="filterLevel2" disabled><option value="">-- اختر الأول --</option></select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label"><i class="bi bi-geo-alt me-1 text-success"></i>المستوى الثالث</label>
                        <select class="form-select" id="filterLevel3" disabled><option value="">-- اختر الثاني --</option></select>
                    </div>
                </div>
                <input type="hidden" id="ExternalUnitId" name="ExternalUnitId" value="@Model.ExternalUnitId" />
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div id="selectedUnitDisplay">
                        @if (!string.IsNullOrEmpty(Model.SelectedUnitName))
                        {
                            <span class="badge badge-approved" style="font-size:.82rem;padding:6px 12px;">
                                <i class="bi bi-building me-1"></i>@Model.SelectedUnitName
                            </span>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-funnel"></i> تطبيق</button>
                        <a href="/Reports" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> إعادة تعيين</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ROW 1: KPIs -->
<div class="row mb-4 g-3">
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            <div class="card-body text-center py-4">
                <div class="kpi-ico" style="background:var(--info-light);color:var(--info);"><i class="bi bi-folder"></i></div>
                <div class="kpi-value" style="color:var(--primary);">@Model.ProjectCompletionRate%</div>
                <div class="kpi-label">إكمال المشاريع</div>
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar" style="width:@Model.ProjectCompletionRate%;background:var(--primary);"></div>
                </div>
                <small class="text-muted d-block mt-1">@Model.CompletedProjects من @Model.TotalProjects</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            <div class="card-body text-center py-4">
                <div class="kpi-ico" style="background:var(--success-light);color:var(--success);"><i class="bi bi-list-check"></i></div>
                <div class="kpi-value" style="color:var(--success);">@Model.StepCompletionRate%</div>
                <div class="kpi-label">إكمال الخطوات</div>
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar bg-success" style="width:@Model.StepCompletionRate%;"></div>
                </div>
                <small class="text-muted d-block mt-1">@Model.CompletedSteps من @Model.TotalSteps</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            <div class="card-body text-center py-4">
                <div class="kpi-ico" style="background:var(--warning-light);color:var(--warning);"><i class="bi bi-cash-stack"></i></div>
                @if (Model.BudgetUtilization > 100)
                {
                    <div class="kpi-value" style="color:var(--danger);">@Model.BudgetUtilization%</div>
                }
                else if (Model.BudgetUtilization > 80)
                {
                    <div class="kpi-value" style="color:var(--warning);">@Model.BudgetUtilization%</div>
                }
                else
                {
                    <div class="kpi-value" style="color:var(--info);">@Model.BudgetUtilization%</div>
                }
                <div class="kpi-label">استخدام الميزانية</div>
                <div class="progress mt-2" style="height:5px;">
                    @if (Model.BudgetUtilization > 100)
                    {
                        <div class="progress-bar bg-danger" style="width:100%;"></div>
                    }
                    else
                    {
                        <div class="progress-bar bg-warning" style="width:@Model.BudgetUtilization%;"></div>
                    }
                </div>
                <small class="text-muted d-block mt-1">@Model.TotalActualCost.ToString("N0") / @Model.TotalBudget.ToString("N0")</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card kpi-card h-100">
            @if (delayedItems > 0)
            {
                <div class="card-body text-center py-4" style="border-right:3px solid var(--danger);">
                    <div class="kpi-ico" style="background:var(--danger-light);color:var(--danger);"><i class="bi bi-exclamation-triangle"></i></div>
                    <div class="kpi-value" style="color:var(--danger);">@delayedItems</div>
                    <div class="kpi-label">عناصر متأخرة</div>
                    <div class="d-flex justify-content-center gap-1 mt-2 flex-wrap">
                        <span class="badge badge-cancelled">@Model.DelayedProjects مشروع</span>
                        <span class="badge badge-delayed">@Model.OverdueSteps.Count خطوة</span>
                    </div>
                </div>
            }
            else
            {
                <div class="card-body text-center py-4" style="border-right:3px solid var(--success);">
                    <div class="kpi-ico" style="background:var(--success-light);color:var(--success);"><i class="bi bi-check-circle"></i></div>
                    <div class="kpi-value" style="color:var(--success);">0</div>
                    <div class="kpi-label">عناصر متأخرة</div>
                    <div class="mt-2">
                        <span class="badge badge-completed"><i class="bi bi-check-circle me-1"></i>لا يوجد</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ROW 2: CHARTS -->
<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-pie-chart me-2"></i>توزيع حالات المشاريع
                <small class="text-muted float-end" style="font-size:.72rem;"><i class="bi bi-hand-index me-1"></i>تفاعلي</small>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="projectStatusChart" style="max-height:230px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-bar-chart-horizontal me-2"></i>أداء الوحدات التنظيمية
                <small class="text-muted float-end" style="font-size:.72rem;"><i class="bi bi-hand-index me-1"></i>تفاعلي</small>
            </div>
            <div class="card-body">
                <canvas id="unitPerformanceChart" style="max-height:230px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ROW 3: ALERTS (+ LINE CHART if data exists) -->
<div class="row mb-4 g-3">
    @if (Model.MonthlyProgressData.Any())
    {
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-graph-up me-2"></i>منحنى الإنجاز الشهري</div>
                <div class="card-body">
                    <canvas id="progressLineChart" style="max-height:250px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card h-100">
                <div class="card-header" style="background:var(--danger-light);color:var(--danger);border-bottom-color:#fca5a5;">
                    <i class="bi bi-exclamation-triangle me-2"></i>يتطلب انتباهاً فورياً
                    @if (Model.OverdueProjects.Any() || Model.OverdueSteps.Any())
                    {
                        <span class="badge badge-cancelled float-end">@(Model.OverdueProjects.Count + Model.OverdueSteps.Count)</span>
                    }
                </div>
                <div class="card-body p-2" style="max-height:270px;overflow-y:auto;">
                    @await Html.PartialAsync("_OverdueAlerts", Model)
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header" style="background:var(--danger-light);color:var(--danger);border-bottom-color:#fca5a5;">
                    <i class="bi bi-exclamation-triangle me-2"></i>يتطلب انتباهاً فورياً
                    @if (Model.OverdueProjects.Any() || Model.OverdueSteps.Any())
                    {
                        <span class="badge badge-cancelled float-end">@(Model.OverdueProjects.Count + Model.OverdueSteps.Count)</span>
                    }
                </div>
                <div class="card-body p-2" style="max-height:270px;overflow-y:auto;">
                    @await Html.PartialAsync("_OverdueAlerts", Model)
                </div>
            </div>
        </div>
    }
</div>

<!-- ROW 4: TOP INITIATIVES + UNIT TABLE -->
<div class="row mb-4 g-3">
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header" style="background:var(--success-light);color:var(--success);border-bottom-color:#a7f3d0;">
                <i class="bi bi-trophy me-2"></i>أفضل المبادرات أداءً
            </div>
            <div class="card-body p-0">
                @if (Model.TopInitiatives.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>المبادرة</th>
                                    <th class="text-center" style="width:70px;">المشاريع</th>
                                    <th style="width:120px;">الإنجاز</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.TopInitiatives.Take(6))
                                {
                                    <tr>
                                        <td>
                                            <a href="/Initiatives/Details/@item.Id" class="fw-semibold text-dark text-decoration-none" style="font-size:.85rem;">@item.Name</a>
                                            <div class="text-muted" style="font-size:.75rem;">@item.UnitName</div>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge badge-completed">@item.CompletedProjectsCount</span>/@item.ProjectsCount
                                        </td>
                                        <td class="align-middle">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height:5px;">
                                                    <div class="progress-bar bg-success" style="width:@item.Progress%;"></div>
                                                </div>
                                                <small class="fw-bold text-nowrap">@item.Progress%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox" style="font-size:2rem;opacity:.3;"></i>
                        <p class="mt-2 small">لا توجد مبادرات</p>
                    </div>
                }
            </div>
        </div>
    </div>
    @if (Model.UnitSummaries.Any())
    {
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-building me-2"></i>ملخص أداء الوحدات
                    <small class="text-muted float-end" style="font-size:.72rem;"><i class="bi bi-hand-index me-1"></i>اضغط للتفاصيل</small>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>الوحدة</th>
                                    <th class="text-center">مبادرات</th>
                                    <th class="text-center">مشاريع</th>
                                    <th class="text-center"><span class="text-success">✓</span>/<span class="text-danger">!</span></th>
                                    <th style="width:160px;">الإنجاز</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var unit in Model.UnitSummaries)
                                {
                                    var uid = unit.ExternalUnitId ?? unit.UnitId ?? 0;
                                    var unitNameJs = (unit.UnitName ?? "").Replace("'", "\\'");
                                    string pc;
                                    if (unit.AverageProgress >= 80) { pc = "var(--success)"; }
                                    else if (unit.AverageProgress >= 50) { pc = "var(--primary-light)"; }
                                    else if (unit.AverageProgress >= 30) { pc = "var(--warning)"; }
                                    else { pc = "var(--danger)"; }
                                    <tr style="cursor:pointer;" onclick="showUnitDrillDown('@unitNameJs', @uid)">
                                        <td><strong style="font-size:.875rem;">@unit.UnitName</strong></td>
                                        <td class="text-center">@unit.InitiativeCount</td>
                                        <td class="text-center">@unit.ProjectCount</td>
                                        <td class="text-center">
                                            <span class="badge badge-completed">@unit.CompletedCount</span>
                                            @if (unit.DelayedCount > 0)
                                            {
                                                <span class="badge badge-cancelled">@unit.DelayedCount</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height:8px;">
                                                    <div class="progress-bar" style="width:@(Math.Max(unit.AverageProgress, 5))%;background:@pc;"></div>
                                                </div>
                                                <small class="fw-bold text-nowrap" style="min-width:36px;">@unit.AverageProgress%</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- ROW 5: SUMMARY CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100" style="background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);border:none;">
            <div class="card-body text-white">
                <h6 class="mb-3 opacity-75 fw-semibold"><i class="bi bi-lightning-charge me-2"></i>المبادرات</h6>
                <div class="row text-center g-0">
                    <div class="col-3"><div class="fs-5 fw-bold">@Model.CompletedInitiatives</div><small style="font-size:.68rem;opacity:.7;">مكتمل</small></div>
                    <div class="col-3"><div class="fs-5 fw-bold">@Model.InProgressInitiatives</div><small style="font-size:.68rem;opacity:.7;">جاري</small></div>
                    <div class="col-3"><div class="fs-5 fw-bold">@Model.NotStartedInitiatives</div><small style="font-size:.68rem;opacity:.7;">لم يبدأ</small></div>
                    <div class="col-3"><div class="fs-5 fw-bold">@Model.DelayedInitiatives</div><small style="font-size:.68rem;opacity:.7;">متأخر</small></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100" style="background:linear-gradient(135deg,var(--success) 0%,#10b981 100%);border:none;">
            <div class="card-body text-white">
                <h6 class="mb-3 opacity-75 fw-semibold"><i class="bi bi-folder me-2"></i>المشاريع</h6>
                <div class="row text-center g-0">
                    <div class="col-4"><div class="fs-5 fw-bold">@Model.CompletedProjects</div><small style="font-size:.68rem;opacity:.7;">مكتمل</small></div>
                    <div class="col-4"><div class="fs-5 fw-bold">@Model.InProgressProjects</div><small style="font-size:.68rem;opacity:.7;">جاري</small></div>
                    <div class="col-4"><div class="fs-5 fw-bold">@Model.DelayedProjects</div><small style="font-size:.68rem;opacity:.7;">متأخر</small></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100" style="background:linear-gradient(135deg,var(--info) 0%,#0ea5e9 100%);border:none;">
            <div class="card-body text-white">
                <h6 class="mb-3 opacity-75 fw-semibold"><i class="bi bi-list-check me-2"></i>الخطوات</h6>
                <div class="row text-center g-0">
                    <div class="col-4"><div class="fs-5 fw-bold">@Model.CompletedSteps</div><small style="font-size:.68rem;opacity:.7;">مكتمل</small></div>
                    <div class="col-4"><div class="fs-5 fw-bold">@Model.InProgressSteps</div><small style="font-size:.68rem;opacity:.7;">جاري</small></div>
                    <div class="col-4"><div class="fs-5 fw-bold">@Model.NotStartedSteps</div><small style="font-size:.68rem;opacity:.7;">لم يبدأ</small></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Drill-Down Data (hidden) - filled by partial -->
<div id="delayedDrillData" style="display:none;">
    @await Html.PartialAsync("_OverdueAlerts", Model)
</div>

<!-- DRILL-DOWN MODAL -->
<div class="modal fade" id="drillDownModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-list-ul me-2"></i><span id="drillDownLabel">التفاصيل</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="drillDownContent"></div>
            <div class="modal-footer">
                <a href="#" id="drillDownLink" class="btn btn-primary btn-sm">
                    <i class="bi bi-box-arrow-up-right me-1"></i>عرض الكل
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script>
        window.ReportsConfig = {
            selectedExternalUnitId: '@(Model.ExternalUnitId?.ToString() ?? "")'
        };
    </script>
    <script src="~/js/reports-dashboard.js"></script>
}
