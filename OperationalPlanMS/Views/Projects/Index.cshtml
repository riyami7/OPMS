@model OperationalPlanMS.Models.ViewModels.ProjectListViewModel
@{
    ViewData["Title"] = "المشاريع";
    var canEdit = (bool)(ViewBag.CanEdit ?? false);
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-title">
        <h4><i class="bi bi-folder me-2 text-success"></i>المشاريع</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">الرئيسية</a></li>
                <li class="breadcrumb-item active">المشاريع</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel"></i>فلاتر البحث
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index" id="filterForm">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">البحث</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" asp-for="SearchTerm" placeholder="الاسم أو الكود..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">المبادرة</label>
                    <select class="form-select" asp-for="InitiativeId" asp-items="Model.Initiatives">
                        <option value="">-- جميع المبادرات --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">المستوى الأول</label>
                    <select class="form-select" id="filterLevel1"><option value="">-- جاري التحميل --</option></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">المستوى الثاني</label>
                    <select class="form-select" id="filterLevel2" disabled><option value="">-- اختر الأول --</option></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">المستوى الثالث</label>
                    <select class="form-select" id="filterLevel3" disabled><option value="">-- اختر الثاني --</option></select>
                </div>
            </div>
            <input type="hidden" id="ExternalUnitId" name="ExternalUnitId" value="@ViewBag.ExternalUnitId" />
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div id="selectedUnitDisplay">
                    @if (ViewBag.SelectedUnitName != null)
                    {
                        <span class="badge" style="background:var(--info-light);color:var(--info);font-size:.82rem;padding:6px 12px;">
                            <i class="bi bi-building me-1"></i>@ViewBag.SelectedUnitName
                        </span>
                    }
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i>بحث</button>
                    <a href="/Projects" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i>إعادة تعيين</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Results Info -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">
        <i class="bi bi-list-ul me-1"></i>عرض <strong>@Model.Projects.Count</strong> من <strong>@Model.TotalCount</strong> نتيجة
    </span>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:100px;">الكود</th>
                        <th>المشروع</th>
                        <th>المبادرة</th>
                        <th>الوحدة التنظيمية</th>
                        <th style="width:80px;" class="text-center">الخطوات</th>
                        <th style="width:150px;">التقدم</th>
                        <th style="width:100px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Projects.Any())
                    {
                        @foreach (var item in Model.Projects)
                        {
                            var progressClass = item.ProgressPercentage < 40 ? "bg-danger" :
                            item.ProgressPercentage < 70 ? "bg-warning" : "bg-success";
                            var unitName = item.ExternalUnitName ?? "-";
                            var stepsCount = item.Steps?.Count ?? 0;
                            var completedSteps = item.Steps?.Count(s => s.ProgressPercentage >= 100) ?? 0;
                            var isAllDone = completedSteps == stepsCount && stepsCount > 0;
                            <tr>
                                <td><code class="text-success fw-bold">@item.Code</code></td>
                                <td>
                                    <a href="/Projects/Details/@item.Id" class="fw-bold text-decoration-none text-dark">@item.NameAr</a>
                                    @if (!string.IsNullOrEmpty(item.NameEn))
                                    {
                                        <br />
                                        <small class="text-muted">@item.NameEn</small>
         }
                                </td>
                                <td>
                                    <a href="/Initiatives/Details/@item.InitiativeId" class="text-decoration-none" style="font-size:.85rem;">
                                        <i class="bi bi-lightning-charge text-warning me-1"></i>@item.Initiative?.NameAr
                                    </a>
                                </td>
                                <td><small class="text-muted"><i class="bi bi-building me-1"></i>@unitName</small></td>
                                <td class="text-center">
                                    <span class="badge rounded-pill" style="background:@(isAllDone ? "var(--success-light)" : "var(--border)");color:@(isAllDone ? "var(--success)" : "var(--text-muted)");">
                                        @completedSteps / @stepsCount
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-fill" style="height:7px;">
                                            <div class="progress-bar @progressClass" style="width:@item.ProgressPercentage%;"></div>
                                        </div>
                                        <small class="text-nowrap fw-bold" style="min-width:35px;">@item.ProgressPercentage%</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/Projects/Details/@item.Id" class="btn btn-sm btn-outline-primary" title="عرض"><i class="bi bi-eye"></i></a>
                                        @if (canEdit)
                                        {
                                            <a href="/Projects/Edit/@item.Id" class="btn btn-sm btn-outline-warning" title="تعديل"><i class="bi bi-pencil"></i></a>
                                            <a href="/Projects/Delete/@item.Id" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-folder text-muted" style="font-size:3rem;opacity:.3;"></i>
                                <h6 class="mt-3 text-muted fw-normal">لا توجد مشاريع</h6>
                                <p class="text-muted small mb-0">لإضافة مشروع، اذهب إلى صفحة المبادرة المطلوبة</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?CurrentPage=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm&InitiativeId=@Model.InitiativeId&ExternalUnitId=@ViewBag.ExternalUnitId"><i class="bi bi-chevron-right"></i></a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?CurrentPage=@i&SearchTerm=@Model.SearchTerm&InitiativeId=@Model.InitiativeId&ExternalUnitId=@ViewBag.ExternalUnitId">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?CurrentPage=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm&InitiativeId=@Model.InitiativeId&ExternalUnitId=@ViewBag.ExternalUnitId"><i class="bi bi-chevron-left"></i></a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        var allUnits = [], selectedExternalUnitId = '@(ViewBag.ExternalUnitId ?? "")';
        document.addEventListener('DOMContentLoaded', function () {
            loadOrganizationalUnits();
            document.getElementById('filterLevel1').addEventListener('change', onLevel1Change);
            document.getElementById('filterLevel2').addEventListener('change', onLevel2Change);
            document.getElementById('filterLevel3').addEventListener('change', onLevel3Change);
        });
        function loadOrganizationalUnits() {
            fetch('/api/OrganizationApi/units/all')
                .then(r => r.ok ? r.json() : Promise.reject())
                .then(data => { allUnits = data; populateFilterLevel1(); if (selectedExternalUnitId) restoreFilterSelection(selectedExternalUnitId); })
                .catch(() => document.getElementById('filterLevel1').innerHTML = '<option value="">-- فشل التحميل --</option>');
        }
        function populateFilterLevel1() {
            var s = document.getElementById('filterLevel1');
            s.innerHTML = '<option value="">-- جميع الوحدات --</option>';
            allUnits.filter(u => u.code=='00001'&& ( !u.parentId || u.parentId === 0)).forEach(u => { var o = document.createElement('option'); o.value = u.id; o.textContent = u.name; s.appendChild(o); });
        }
        function fillSelect(el, items, ph) { el.innerHTML = '<option value="">' + ph + '</option>'; items.forEach(u => { var o = document.createElement('option'); o.value = u.id; o.textContent = u.name; el.appendChild(o); }); }
        function onLevel1Change() {
            var id = this.value, l2 = document.getElementById('filterLevel2'), l3 = document.getElementById('filterLevel3');
            l2.disabled = true; l3.innerHTML = '<option value="">-- اختر الثاني --</option>'; l3.disabled = true;
            if (id) { var ch = allUnits.filter(u => u.parentId === id); fillSelect(l2, ch, ch.length ? '-- جميع الفروع --' : '-- لا توجد فروع --'); l2.disabled = !ch.length; updateSelectedUnit(id); }
            else { l2.innerHTML = '<option value="">-- اختر الأول --</option>'; document.getElementById('ExternalUnitId').value = ''; updateSelectedUnitDisplay(''); }
        }
        function onLevel2Change() {
            var id = this.value, l3 = document.getElementById('filterLevel3');
            l3.disabled = true;
            if (id) { var ch = allUnits.filter(u => u.parentId === id); fillSelect(l3, ch, ch.length ? '-- جميع الأقسام --' : '-- لا توجد أقسام --'); l3.disabled = !ch.length; updateSelectedUnit(id); }
            else { l3.innerHTML = '<option value="">-- اختر الثاني --</option>'; var l1v = document.getElementById('filterLevel1').value; if (l1v) updateSelectedUnit(l1v); else { document.getElementById('ExternalUnitId').value = ''; updateSelectedUnitDisplay(''); } }
        }
        function onLevel3Change() { var id = this.value; if (id) updateSelectedUnit(id); else { var l2v = document.getElementById('filterLevel2').value; if (l2v) updateSelectedUnit(l2v); } }
        function updateSelectedUnit(id) {
            document.getElementById('ExternalUnitId').value = id;
            var unit = allUnits.find(u => u.id === id);
            if (unit) updateSelectedUnitDisplay(unit.name);
        }
        function updateSelectedUnitDisplay(name) {
            var d = document.getElementById('selectedUnitDisplay');
            d.innerHTML = name ? '<span class="badge" style="background:var(--info-light);color:var(--info);font-size:.82rem;padding:6px 12px;"><i class="bi bi-building me-1"></i>' + name + '</span>' : '';
        }
        function restoreFilterSelection(unitId) {
            var unit = allUnits.find(u => u.id === unitId); if (!unit) return;
            var hierarchy = [], current = unit;
            while (current) { hierarchy.unshift(current); var pid = current.parentId; current = allUnits.find(u => u.id === pid); }
            document.getElementById('filterLevel1').value = hierarchy[0].id;
            onLevel1Change.call(document.getElementById('filterLevel1'));
            setTimeout(() => {
                if (hierarchy.length >= 2) { document.getElementById('filterLevel2').value = hierarchy[1].id; onLevel2Change.call(document.getElementById('filterLevel2')); setTimeout(() => { if (hierarchy.length >= 3) { document.getElementById('filterLevel3').value = hierarchy[2].id; updateSelectedUnit(hierarchy[2].id); } }, 100); }
            }, 100);
        }
    </script>
}
