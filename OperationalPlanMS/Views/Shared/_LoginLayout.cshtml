<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة الخطط التشغيلية</title>

    <!-- Local Fonts -->
    <link href="~/css/fonts.css" rel="stylesheet">

    <style>
        :root {
            --primary: #6366f1;
            --primary-dk: #4f46e5;
            --primary-lt: #a5b4fc;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #06b6d4;
            --txt-1: #1a1a2e;
            --txt-2: #6b7280;
            --txt-3: #9ca3af;
            --bg-white: #ffffff;
            --bg-soft: #f3f4f6;
            --bg-dark: #0d1117;
            --bg-card: #161b27;
            --border: rgba(255,255,255,0.06);
            --glow: rgba(99,102,241,0.35);
            --grad: linear-gradient(135deg,#667eea 0%,#764ba2 100%);
        }

        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'AlQabas', 'Segoe UI', Tahoma, sans-serif;
            background: var(--bg-dark);
            min-height: 100vh;
            overflow-x: hidden;
            color: #e2e8f0;
        }

            /* ── animated grid background ── */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px);
                background-size: 48px 48px;
                pointer-events: none;
                z-index: 0;
            }

            /* ── noise grain overlay ── */
            body::after {
                content: '';
                position: fixed;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
                pointer-events: none;
                z-index: 0;
                opacity: .5;
            }

        /* ═══════════════════════════════════
                   OUTER SHELL
                ═══════════════════════════════════ */
        .shell {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 520px;
            gap: 0;
        }

        /* ═══════════════════════════════════
                   LEFT PANEL  (visual / brand)
                ═══════════════════════════════════ */
        .panel-left {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 3rem;
            overflow: hidden;
        }

            /* large radial bloom */
            .panel-left::before {
                content: '';
                position: absolute;
                width: 700px;
                height: 700px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(99,102,241,.18) 0%, transparent 70%);
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                pointer-events: none;
            }

        .brand-stack {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 0;
        }

        /* hexagonal logo frame */
        .hex-frame {
            position: relative;
            width: 160px;
            height: 160px;
            margin-bottom: 2.5rem;
        }

            .hex-frame svg.hex-bg {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                animation: hexSpin 20s linear infinite;
                opacity: .5;
            }

            .hex-frame img {
                position: absolute;
                inset: 20px;
                width: calc(100% - 40px);
                height: calc(100% - 40px);
                object-fit: contain;
                filter: drop-shadow(0 0 20px rgba(99,102,241,.6));
                animation: floatLogo 4s ease-in-out infinite;
            }

        @@keyframes hexSpin {
            from

        {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }

        }
        @@keyframes floatLogo {
            0%,100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }

        }

        .brand-name {
            font-size: 2rem;
            font-weight: 900;
            color: #f1f5f9;
            line-height: 1.3;
            letter-spacing: -0.5px;
            margin-bottom: .5rem;
        }

        .brand-en {
            font-size: .9rem;
            font-weight: 400;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--primary-lt);
            margin-bottom: 3.5rem;
        }

        /* stats row */
        .stats-row {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
            justify-content: center;
            margin-bottom: 3rem;
        }

        .stat-chip {
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(99,102,241,.2);
            border-radius: 100px;
            padding: .45rem 1.1rem;
            font-size: .82rem;
            color: var(--primary-lt);
            display: flex;
            align-items: center;
            gap: .5rem;
            backdrop-filter: blur(8px);
            transition: background .3s;
        }

            .stat-chip:hover {
                background: rgba(99,102,241,.15);
            }

            .stat-chip .dot {
                width: 7px;
                height: 7px;
                border-radius: 50%;
                background: var(--success);
                animation: pulse 2s infinite;
            }
        @@keyframes pulse {
            0%,100%

        {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: .5;
            transform: scale(1.5);
        }

        }

        /* feature cards */
        .feat-grid {
            display: flex;
            flex-direction: column;
            gap: .9rem;
            width: 100%;
            max-width: 380px;
        }

        .feat-card {
            background: rgba(255,255,255,.035);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            backdrop-filter: blur(12px);
            transition: all .3s ease;
            cursor: default;
        }

            .feat-card:hover {
                background: rgba(99,102,241,.1);
                border-color: rgba(99,102,241,.3);
                transform: translateX(6px);
            }

        .feat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: var(--grad);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: white;
        }

        .feat-copy strong {
            display: block;
            font-size: .95rem;
            font-weight: 700;
            color: #f1f5f9;
            margin-bottom: .15rem;
        }

        .feat-copy span {
            font-size: .8rem;
            color: var(--txt-3);
        }

        /* corner accent rings */
        .ring {
            position: absolute;
            border-radius: 50%;
            border: 1px solid rgba(99,102,241,.12);
            pointer-events: none;
        }

        .ring-1 {
            width: 320px;
            height: 320px;
            top: -80px;
            right: -60px;
        }

        .ring-2 {
            width: 220px;
            height: 220px;
            bottom: -40px;
            left: -30px;
        }

        .ring-3 {
            width: 120px;
            height: 120px;
            bottom: 25%;
            right: 8%;
        }

        /* ═══════════════════════════════════
                   RIGHT PANEL  (form)
                ═══════════════════════════════════ */
        .panel-right {
            position: relative;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 2.5rem;
            border-right: 1px solid var(--border);
        }

            /* top glowing line */
            .panel-right::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--grad);
                border-radius: 0 0 4px 4px;
            }

            /* subtle inner glow */
            .panel-right::after {
                content: '';
                position: absolute;
                top: -200px;
                left: 50%;
                transform: translateX(-50%);
                width: 500px;
                height: 400px;
                background: radial-gradient(circle, rgba(99,102,241,.07) 0%, transparent 70%);
                pointer-events: none;
            }

        .form-box {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 380px;
            animation: slideUp .6s cubic-bezier(.16,1,.3,1) forwards;
            opacity: 0;
            transform: translateY(24px);
        }
        @@keyframes slideUp {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* ── form header ── */
        .fh {
            margin-bottom: 2.5rem;
        }

        .fh-badge {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            background: rgba(99,102,241,.12);
            border: 1px solid rgba(99,102,241,.25);
            border-radius: 100px;
            padding: .3rem .9rem;
            font-size: .75rem;
            color: var(--primary-lt);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 1.2rem;
        }

        .fh h2 {
            font-size: 2rem;
            font-weight: 800;
            color: #f1f5f9;
            line-height: 1.2;
            margin-bottom: .4rem;
        }

        .fh p {
            font-size: .9rem;
            color: var(--txt-3);
        }

        /* ── error box ── */
        .err-box {
            background: rgba(239,68,68,.08);
            border: 1px solid rgba(239,68,68,.25);
            border-radius: 10px;
            padding: .85rem 1rem;
            margin-bottom: 1.5rem;
            color: #fca5a5;
            font-size: .88rem;
            display: none;
        }

            .err-box:not(:empty) {
                display: block;
            }

        /* ── field wrapper ── */
        .field {
            margin-bottom: 1.25rem;
        }

        .field-label {
            display: block;
            font-size: .82rem;
            font-weight: 600;
            color: var(--txt-3);
            margin-bottom: .5rem;
            letter-spacing: .5px;
        }

        .field-control {
            position: relative;
            display: flex;
            align-items: center;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 12px;
            transition: all .25s ease;
            overflow: hidden;
        }

            .field-control:focus-within {
                border-color: var(--primary);
                background: rgba(99,102,241,.07);
                box-shadow: 0 0 0 3px rgba(99,102,241,.2);
            }

        .fc-icon {
            width: 50px;
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--txt-3);
            flex-shrink: 0;
            transition: color .25s;
            border-left: 1px solid rgba(255,255,255,.06);
        }

        .field-control:focus-within .fc-icon {
            color: var(--primary-lt);
        }

        .fc-input {
            flex: 1;
            height: 52px;
            background: transparent;
            border: none;
            outline: none;
            padding: 0 1rem;
            font-size: .97rem;
            font-family: inherit;
            color: #f1f5f9;
            caret-color: var(--primary-lt);
        }

            .fc-input::placeholder {
                color: rgba(255,255,255,.2);
            }

        .fc-toggle {
            width: 46px;
            height: 52px;
            background: transparent;
            border: none;
            cursor: pointer;
            color: var(--txt-3);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color .25s;
        }

            .fc-toggle:hover {
                color: var(--primary-lt);
            }

        .field-error {
            display: block;
            font-size: .78rem;
            color: #fca5a5;
            margin-top: .35rem;
            padding-right: .25rem;
        }

            .field-error:empty {
                display: none;
            }

        /* ── remember row ── */
        .meta-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 1.5rem 0;
        }

        .chk-label {
            display: flex;
            align-items: center;
            gap: .65rem;
            cursor: pointer;
            user-select: none;
        }

            .chk-label input {
                display: none;
            }

        .chk-box {
            width: 20px;
            height: 20px;
            border: 1.5px solid rgba(255,255,255,.2);
            border-radius: 6px;
            background: transparent;
            position: relative;
            flex-shrink: 0;
            transition: all .2s;
        }

            .chk-box::after {
                content: '';
                position: absolute;
                display: none;
                right: 5px;
                top: 1px;
                width: 6px;
                height: 11px;
                border: solid white;
                border-width: 0 2px 2px 0;
                transform: rotate(45deg);
            }

        .chk-label input:checked ~ .chk-box {
            background: var(--primary);
            border-color: var(--primary);
        }

            .chk-label input:checked ~ .chk-box::after {
                display: block;
            }

        .chk-text {
            font-size: .88rem;
            color: var(--txt-3);
        }

        /* ── submit button ── */
        .btn-go {
            width: 100%;
            height: 54px;
            background: var(--grad);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1.05rem;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .75rem;
            position: relative;
            overflow: hidden;
            transition: all .3s ease;
            box-shadow: 0 4px 20px rgba(99,102,241,.35);
            margin-top: .5rem;
        }

            .btn-go::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(255,255,255,.15) 0%, transparent 60%);
                border-radius: inherit;
            }

            .btn-go:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(99,102,241,.5);
            }

            .btn-go:active {
                transform: translateY(0);
            }

            .btn-go .arrow-wrap {
                width: 30px;
                height: 30px;
                background: rgba(255,255,255,.18);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: transform .3s;
            }

            .btn-go:hover .arrow-wrap {
                transform: translateX(-5px);
            }

        /* ── footer ── */
        .form-foot {
            text-align: center;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255,255,255,.06);
        }

            .form-foot p {
                font-size: .8rem;
                color: rgba(255,255,255,.2);
            }

        /* ── divider with shimmer ── */
        .shimmer-line {
            position: relative;
            height: 1px;
            background: rgba(255,255,255,.06);
            margin: 2rem 0;
            overflow: hidden;
        }

            .shimmer-line::after {
                content: '';
                position: absolute;
                height: 100%;
                width: 60%;
                background: linear-gradient(90deg, transparent, rgba(99,102,241,.5), transparent);
                animation: shimmer 3s ease-in-out infinite;
            }
        @@keyframes shimmer {
            0%

        {
            left: -60%;
        }

        100% {
            left: 160%;
        }

        }

        /* ═══════════════════════════════════
                   RESPONSIVE
                ═══════════════════════════════════ */
        @@media (max-width: 900px) {
            .shell {
                grid-template-columns: 1fr;
                grid-template-rows: auto 1fr;
            }

            .panel-right {
                border-right: none;
                border-top: 1px solid var(--border);
                padding: 2.5rem 1.5rem 3rem;
            }

            .panel-left {
                padding: 3rem 2rem 2rem;
            }

            .feat-grid {
                display: none;
            }

            .stats-row {
                margin-bottom: 0;
            }

            .brand-en {
                margin-bottom: 1.5rem;
            }
        }

        @@media (max-width: 480px) {
            .brand-name {
                font-size: 1.5rem;
            }

            .hex-frame {
                width: 110px;
                height: 110px;
                margin-bottom: 1.5rem;
            }
        }
    </style>
</head>
<body>
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
