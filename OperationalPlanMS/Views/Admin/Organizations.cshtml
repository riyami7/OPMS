@model OperationalPlanMS.Models.ViewModels.OrganizationListViewModel
@{
    ViewData["Title"] = "إدارة المنظمات";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">إدارة المنظمات</h4>
        <p class="text-muted mb-0">عرض وإدارة المنظمات</p>
    </div>
    <div>
        <a href="/Admin/OrganizationCreate" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>إضافة منظمة
        </a>
        <a href="/Admin" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-arrow-right me-2"></i>رجوع
        </a>
    </div>
</div>

<!-- Search -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-10">
                    <input type="text" class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="البحث بالاسم أو الكود..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-1"></i>بحث
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم بالعربية</th>
                        <th>الاسم بالإنجليزية</th>
                        <th>الحالة</th>
                        <th style="width: 150px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Organizations.Any())
                    {
                        @foreach (var item in Model.Organizations)
                        {
                            <tr>
                                <td><code>@item.Code</code></td>
                                <td>@item.NameAr</td>
                                <td dir="ltr" class="text-end">@item.NameEn</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Admin/OrganizationEdit/@item.Id" class="btn btn-outline-warning" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="OrganizationDelete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من الحذف؟');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="bi bi-building" style="font-size: 2rem;"></i>
                                <p class="mt-2 mb-0">لا توجد منظمات</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
