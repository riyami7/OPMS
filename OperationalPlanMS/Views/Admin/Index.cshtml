@{
    ViewData["Title"] = "لوحة الإدارة";
}

<div class="mb-4">
    <h4 class="mb-1">لوحة إدارة النظام</h4>
    <p class="text-muted">إدارة البيانات الأساسية والمستخدمين</p>
</div>

<div class="row">
    <!-- إعدادات النظام (الرؤية والمهمة) -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-dark">
            <div class="card-body text-center">
                <i class="bi bi-gear-wide-connected text-dark" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">الرؤية والمهمة</h5>
                <p class="card-text text-muted">إعدادات الرؤية والمهمة للنظام والوحدات</p>
                <a href="/StrategicPlanning/VisionMission" class="btn btn-dark">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- التخطيط الاستراتيجي -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-purple" style="border-color: #6f42c1 !important;">
            <div class="card-body text-center">
                <i class="bi bi-diagram-3-fill" style="font-size: 3rem; color: #6f42c1;"></i>
                <h5 class="card-title mt-3">التخطيط الاستراتيجي</h5>
                <p class="card-text text-muted">المحاور والأهداف والقيم</p>
                <a href="/StrategicPlanning" class="btn" style="background-color: #6f42c1; color: white;">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- التكلفة المالية -->
    <div class="col-md-4 mb-4">
        <div class="card h-100" style="border-color: #20c997 !important;">
            <div class="card-body text-center">
                <i class="bi bi-cash-stack" style="font-size: 3rem; color: #20c997;"></i>
                <h5 class="card-title mt-3">التكلفة المالية</h5>
                <p class="card-text text-muted">إدارة أنواع التكاليف المالية</p>
                <a href="/StrategicPlanning/FinancialCosts" class="btn" style="background-color: #20c997; color: white;">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- المنظمات -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-primary">
            <div class="card-body text-center">
                <i class="bi bi-building text-primary" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">المنظمات</h5>
                <p class="card-text text-muted">إدارة المنظمات والجهات</p>
                <a href="/Admin/Organizations" class="btn btn-primary">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- الوحدات التنظيمية -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-success">
            <div class="card-body text-center">
                <i class="bi bi-diagram-3 text-success" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">الوحدات التنظيمية</h5>
                <p class="card-text text-muted">إدارة الهيكل التنظيمي</p>
                <a href="/Admin/OrganizationalUnits" class="btn btn-success">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- جهات المساندة -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-danger">
            <div class="card-body text-center">
                <i class="bi bi-building-add text-danger" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">جهات المساندة</h5>
                <p class="card-text text-muted">إدارة الجهات المساندة للمشاريع</p>
                <a href="/SupportingEntities" class="btn btn-danger">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- السنوات المالية -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-warning">
            <div class="card-body text-center">
                <i class="bi bi-calendar-range text-warning" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">السنوات المالية</h5>
                <p class="card-text text-muted">إدارة السنوات المالية</p>
                <a href="/FiscalYears" class="btn btn-warning">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- المستخدمين -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-info">
            <div class="card-body text-center">
                <i class="bi bi-people text-info" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">المستخدمين</h5>
                <p class="card-text text-muted">إدارة حسابات المستخدمين</p>
                <a href="/Users" class="btn btn-info text-white">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>

    <!-- الأدوار -->
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-secondary">
            <div class="card-body text-center">
                <i class="bi bi-shield-lock text-secondary" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-3">الأدوار</h5>
                <p class="card-text text-muted">عرض وتعديل الأدوار</p>
                <a href="/Roles" class="btn btn-secondary">
                    <i class="bi bi-gear me-2"></i>إدارة
                </a>
            </div>
        </div>
    </div>
</div>
