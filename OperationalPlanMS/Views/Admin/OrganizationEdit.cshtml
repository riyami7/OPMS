@model OperationalPlanMS.Models.ViewModels.OrganizationFormViewModel
@{
    ViewData["Title"] = "تعديل منظمة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">تعديل المنظمة</h4>
        <p class="text-muted mb-0">@Model.NameAr</p>
    </div>
    <a href="/Admin/Organizations" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right me-2"></i>رجوع
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="OrganizationEdit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label class="form-label">الكود</label>
                        <input type="text" class="form-control" value="@Model.Code" readonly disabled />
                        <small class="text-muted">الكود لا يمكن تعديله</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameAr" class="form-label"></label>
                        <input asp-for="NameAr" class="form-control" />
                        <span asp-validation-for="NameAr" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameEn" class="form-label"></label>
                        <input asp-for="NameEn" class="form-control" dir="ltr" />
                        <span asp-validation-for="NameEn" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>حفظ التغييرات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
