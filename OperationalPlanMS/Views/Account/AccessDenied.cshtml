@{
    ViewData["Title"] = "الوصول مرفوض";
    Layout = "_LoginLayout";
}

<div class="login-card">
    <div class="login-header" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">
        <i class="bi bi-shield-exclamation"></i>
        <h1>الوصول مرفوض</h1>
        <p>Access Denied</p>
    </div>

    <div class="login-body text-center">
        <div class="mb-4">
            <i class="bi bi-x-circle text-danger" style="font-size: 4rem;"></i>
        </div>
        <h4 class="mb-3">ليس لديك صلاحية للوصول إلى هذه الصفحة</h4>
        <p class="text-muted mb-4">You do not have permission to access this page.</p>

        <a href="/" class="btn btn-primary btn-login">
            <i class="bi bi-house me-2"></i>
            العودة للرئيسية
        </a>
    </div>

    <div class="login-footer">
        <p class="mb-0">&copy; 2026 - نظام إدارة الخطط التشغيلية</p>
    </div>
</div>
