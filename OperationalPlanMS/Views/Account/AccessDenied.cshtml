@{
    ViewData["Title"] = "الوصول مرفوض";
    Layout = "_LoginLayout";
}

<div class="login-card" style="max-width: 480px;">
    <div class="login-header" style="background: linear-gradient(135deg, #0F2544 0%, #1E4976 100%); padding: 40px 30px;">
        <div style="width:72px; height:72px; margin:0 auto 16px; background:rgba(201,168,76,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="bi bi-shield-lock" style="font-size:32px; color:#C9A84C;"></i>
        </div>
        <h1 style="font-size:22px; margin-bottom:6px;">الوصول مرفوض</h1>
        <p style="opacity:0.7; font-size:14px; margin:0;">Access Denied</p>
    </div>

    <div class="login-body text-center" style="padding: 30px;">
        <p style="font-size:15px; color:#334155; line-height:1.8; margin-bottom:8px;">
            ليس لديك صلاحية للوصول إلى هذه الصفحة.
        </p>
        <p style="font-size:13px; color:#94a3b8; margin-bottom:24px;">
            إذا كنت تعتقد أن هذا خطأ، تواصل مع مدير النظام.
        </p>

        <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
            <a href="/" class="btn btn-primary" style="background:linear-gradient(135deg, #0F2544, #1E4976); border:none; padding:10px 24px;">
                <i class="bi bi-house me-2"></i>الرئيسية
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary" style="padding:10px 24px;">
                <i class="bi bi-arrow-right me-2"></i>رجوع
            </button>
        </div>
    </div>

    <div class="login-footer">
        <p class="mb-0">&copy; 2026 - نظام إدارة الخطط التشغيلية</p>
    </div>
</div>
